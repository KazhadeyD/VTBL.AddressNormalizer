<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="internal-nlog.txt">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <target xsi:type="Console"
            name="console"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}|CorrelationId=${mdlc:item=CorrelationId}|${exception:format=tostring}" />
    <target xsi:type="File"
            name="file"
            fileName="logs/webapi-${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}|CorrelationId=${mdlc:item=CorrelationId}|${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- Согласовано с appsettings: Microsoft → Warning+, остальное → Information+ -->
    <logger name="Microsoft.*" minlevel="Warn" writeTo="console,file" final="true" />
    <logger name="Microsoft" minlevel="Warn" writeTo="console,file" final="true" />
    <logger name="*" minlevel="Info" writeTo="console,file" />
  </rules>
</nlog>
